# GitHub API configuration for fetching writing history
# Required:
GITHUB_OWNER=your-username
GITHUB_REPO=idealists-site

# Optional but recommended (avoids rate limits):
# Create at: https://github.com/settings/tokens
# No special permissions needed for public repos
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# GitHub OAuth for annotations (optional)
# Create at: https://github.com/settings/developers
GITHUB_CLIENT_ID=your-client-id
GITHUB_CLIENT_SECRET=your-client-secret

# Interviewer backend (FastAPI, exposed via ngrok or a reserved domain).
# Used by /interview. PUBLIC_* vars are baked at build time so any change here
# requires a redeploy / dev-server restart.
PUBLIC_INTERVIEWER_API=https://your-interviewer-host.example.com
